{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quickstart CLI Summary",
  "type": "object",
  "required": ["status", "job_id", "duration_sec", "tickers"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "warning", "failure"]
    },
    "job_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "duration_sec": {
      "type": "number",
      "minimum": 0
    },
    "tickers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "provider", "status"],
        "properties": {
          "ticker": { "type": "string" },
          "provider": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "warning", "failure"] },
          "rows_ingested": { "type": ["integer", "null"], "minimum": 0 },
          "rows_returns": { "type": ["integer", "null"], "minimum": 0 },
          "snapshot_path": { "type": ["string", "null"] },
          "snapshot_checksum": { "type": ["string", "null"], "pattern": "^[0-9a-fA-F]{64}$" },
          "error_message": { "type": ["string", "null"] }
        }
      }
    }
  }
}
