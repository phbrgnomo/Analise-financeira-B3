{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health / Metrics Schema",
  "oneOf": [
    {
      "type": "object",
      "required": ["status", "timestamp", "metrics", "thresholds"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy", "unknown"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "metrics": {
          "type": "object",
          "required": ["ingest_lag_seconds", "errors_last_24h", "jobs_last_24h", "avg_latency_seconds"],
          "properties": {
            "ingest_lag_seconds": { "type": ["number", "null"], "minimum": 0 },
            "errors_last_24h": { "type": "integer", "minimum": 0 },
            "jobs_last_24h": { "type": "integer", "minimum": 0 },
            "avg_latency_seconds": { "anyOf": [ { "type": "number", "minimum": 0 }, { "type": "null" } ] }
          },
          "additionalProperties": false
        },
        "thresholds": {
          "type": "object",
          "required": ["ingest_lag_seconds"],
          "properties": {
            "ingest_lag_seconds": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["status", "paths", "metrics"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "warn", "error"]
        },
        "paths": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["ok", "warn", "error"] },
            "reasons": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "object",
          "required": ["status", "timestamp", "metrics", "thresholds"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["healthy", "degraded", "unhealthy", "unknown"]
            },
            "timestamp": { "type": "string", "format": "date-time" },
            "metrics": {
              "type": "object",
              "required": ["ingest_lag_seconds", "errors_last_24h", "jobs_last_24h", "avg_latency_seconds"],
              "properties": {
                "ingest_lag_seconds": { "type": ["number", "null"], "minimum": 0 },
                "errors_last_24h": { "type": "integer", "minimum": 0 },
                "jobs_last_24h": { "type": "integer", "minimum": 0 },
                "avg_latency_seconds": { "anyOf": [ { "type": "number", "minimum": 0 }, { "type": "null" } ] }
              },
              "additionalProperties": false
            },
            "thresholds": {
              "type": "object",
              "required": ["ingest_lag_seconds"],
              "properties": {
                "ingest_lag_seconds": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}
