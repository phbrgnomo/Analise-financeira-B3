   "source": [
    "# Returns Consumer - Quickstart\n",
    "\n",
    "Exemplo mínimo mostrando como ler a tabela `returns` e calcular retorno acumulado usando pandas. Use este notebook como referência para consumidores (notebooks/modelagem)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6f187867",
   "metadata": {},
   "outputs": [],
    "import sqlite3\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "conn = sqlite3.connect('dados/data.db')\n",
    "ticker = 'PETR4.SA'\n",
    "df = pd.read_sql_query(\n",
    "    \"SELECT date, return FROM returns WHERE ticker = ? ORDER BY date\",\n",
    "    conn,\n",
    "    params=(ticker,),\n",
    "    parse_dates=['date']\n",
    ")\n",
    "df = df.set_index('date')\n",
    "df['cumulative_return'] = (1 + df['return']).cumprod() - 1\n",
    "print(df.tail())\n",
    "conn.close()"
    "conn.close()"
   ]
  }
