{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ingest Log Entry",
  "type": "object",
  "required": ["job_id", "ticker", "status", "created_at"],
  "properties": {
    "job_id": {"type": "string", "description": "Unique identifier for the ingest job"},
    "ticker": {"type": "string", "description": "Ticker used in the ingest (ex: PETR4.SA)"},
    "source": {"type": "string", "description": "Provider name (ex: yfinance)"},
    "fetched_at": {"type": "string", "format": "date-time"},
    "created_at": {"type": "string", "format": "date-time"},
    "raw_checksum": {"type": "string"},
    "rows": {"type": "integer"},
    "filepath": {"type": "string"},
    "status": {"type": "string", "enum": ["success", "error", "partial"]},
    "reason_code": {"type": "string"},
    "reason_message": {"type": "string"},
    "details": {"type": ["object", "null"]}
  },
  "additionalProperties": true
}
