# Example environment variables for local development
# IMPORTANT: Copy this file to .env and fill real values. Do NOT commit .env.

# Optional: API key for Yahoo or other providers (if required by adapter)
YF_API_KEY=

# Local data directory (relative to repo root)
DATA_DIR=./dados

# Directory for generated snapshots
SNAPSHOT_DIR=./snapshots

# Directory where sample CSVs are written by pull-sample (defaults to dados/samples)
SAMPLES_DIR=./dados/samples

# Keep only the most recent snapshots per ticker prefix
SNAPSHOTS_KEEP_LATEST=1

# Default tickers used by `main run` when --ticker is omitted
DEFAULT_TICKERS=PETR4,ITUB3,BBDC4

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: override default DB path (default used by project is dados/data.db)
DB_PATH=./dados/data.db

# Optional: feature flags or local toggles
FEATURE_ENABLE_EXPERIMENTAL=false

# Optional: override default validation threshold (e.g., 0.1 for 10%)
VALIDATION_INVALID_PERCENT_THRESHOLD=0.1
